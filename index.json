  {
    "id": "zaizaicat_checkin",
    "name": "ZaiZaiCat-Checkin 自用签到合集",
    "type": "repo",
    "link": "https://github.com/Cat-zaizai/ZaiZaiCat-Checkin.git",
    "link_name": "ZaiZaiCat-Checkin",
    "doc_link": "https://cdn.jsdelivr.net/gh/Cat-zaizai/ZaiZaiCat-Checkin@main/README.md",
    "install": "cd ZaiZaiCat-Checkin || exit 1\n${FLS_PYTHON:-python3} -m pip install requests --user\nmkdir -p config\nif [ ! -f config/token.json ]; then\n  echo '{}' > config/token.json\n  echo '已生成 config/token.json，请填写账号配置'\nelse\n  echo 'config/token.json 已存在，不覆盖'\nfi\nif [ ! -f config/notification.json ]; then\n  echo '{}' > config/notification.json\n  echo '已生成 config/notification.json，可选填写推送配置'\nelse\n  echo 'config/notification.json 已存在，不覆盖'\nfi",
    "task_link": "https://cdn.jsdelivr.net/gh/liyw0205/fls-scripts@main/scripts/zaizaicat/tasks.json",
    "created_at": "2026-05-08 00:00:00",
    "updated_at": "2026-05-08 00:00:00"
  },
  {
    "id": "dailycheckin",
    "name": "DailyCheckIn 签到集合",
    "type": "repo",
    "link": "https://github.com/Sitoi/dailycheckin.git",
    "link_name": "dailycheckin",
    "doc_link": "https://cdn.jsdelivr.net/gh/Sitoi/dailycheckin@main/README.md",
    "install": "cd dailycheckin || exit 1\n${FLS_PYTHON:-python3} -m pip install -r requirements.txt\n${FLS_PYTHON:-python3} -m pip install . --user\nif [ ! -f config.json ]; then\n  if [ -f docker/config.template.json ]; then\n    cp docker/config.template.json config.json\n    echo \"已生成 config.json\"\n  else\n    echo \"{}\" > config.json\n    echo \"已生成空 config.json\"\n  fi\nelse\n  echo \"config.json 已存在，不覆盖\"\nfi",
    "task_link": "https://cdn.jsdelivr.net/gh/liyw0205/fls-scripts@main/scripts/dailycheckin/tasks.json",
    "created_at": "2026-05-08 00:00:00",
    "updated_at": "2026-05-08 00:00:00"
  }
]