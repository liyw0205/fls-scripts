  {
    "id": "kg",
    "name": "酷狗音乐签到",
    "type": "repo",
    "link": "https://github.com/develop202/kgcheckin",
    "link_name": "kgcheckin",
    "doc_link": "https://cdn.jsdelivr.net/gh/develop202/kgcheckin@main/README.md",
    "install": "cd kgcheckin\nnpm install",
    "task_cron": [
      {
        "name": "酷狗音乐签到",
        "cron": "30 8 * * *",
        "command": "cd kgcheckin || exit 1\nfls_kill -p 3000\nnpm run main\nfls_kill -p 3000",
        "var": {
          "USERINFO": "[{\"userid\":123456789,\"token\":\"123456789987654321\"}]"
        }
      },
      {
        "name": "酷狗音乐扫码",
        "cron": "30 20 * * *",
        "command": "cd kgcheckin || exit 1\nfls_kill -p 3000\nnpm run qrcodeLogin\nfls_kill -p 3000"
      }
    ],
    "created_at": "2026-05-07 00:00:00",
    "updated_at": "2026-05-07 00:00:00",
    "task_link": ""
  },
